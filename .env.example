# Google AI Studio (Gemini)
GOOGLE_API_KEY=your_api_key_here

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------
# TASK-BASED MODEL ASSIGNMENTS
# ---------------------------------------------------------
# Instead of a global default, assign specific model IDs to specific roles.
# The system automatically detects whether to use Gemini API or local Ollama
# based on the model name (e.g., 'gemini-...' uses API, otherwise Ollama).

# 1. TRANSLATION TASK
# Role: Fast, cheap translation and chunking. Deep reasoning is NOT required.
# Recommended: 'gemini-2.5-flash' (Extremely fast, cheap) or a small local model.
TRANSLATION_MODEL=gemini-2.5-flash

# 2. DRAFTING & COMPRESSION TASK
# Role: Complex context compression and code generation. High reasoning IS required.
# Recommended: 'gemini-2.5-pro' (if complex), 'gemma2:9b' (for local privacy), or 'gemini-2.5-flash' (for max savings).
DRAFTING_MODEL=gemini-2.5-flash
