# AI Provider Selection
# Options: 'gemini', 'ollama', or 'genspark'. 
# If left blank, the system will auto-detect based on the model name.
AI_PROVIDER=gemini

# Google AI Studio (Gemini)
GOOGLE_API_KEY=your_api_key_here

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434

# Genspark (Search AI)
# Requires 'gsk' CLI installed: npm install -g @genspark/cli
# and logged in: gsk login
# GENSPARK_MODEL_TYPE=search

# ---------------------------------------------------------
# TASK-BASED MODEL ASSIGNMENTS
# ---------------------------------------------------------
# You can override the AI provider and model for specific tasks.

# 1. TRANSLATION TASK
# Role: Fast, cheap translation and chunking. Deep reasoning is NOT required.
TRANSLATION_MODEL=gemini-2.5-flash
# Optional: Override provider for this specific task (e.g., 'ollama', 'genspark')
# TRANSLATION_PROVIDER=ollama

# 2. DRAFTING & COMPRESSION TASK
# Role: Complex context compression and code generation. High reasoning IS required.
DRAFTING_MODEL=gemini-2.5-flash
# Optional: Override provider for this specific task (e.g., 'ollama', 'genspark')
# DRAFTING_PROVIDER=ollama
